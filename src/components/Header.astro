---
import HeaderLink from "./HeaderLink.astro";
---

<header class="site-header">
  <div class="topbar">
    <div class="container">
      <div class="topbar-links">
        <a href="tel:+911204567890"
          ><svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
            ></path></svg
          >
          <span class="always-show">+91 120 456 7890</span></a
        >
        <span
          ><a href="mailto:info@saraswatishikshaniketan.edu.in"
            ><svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="m4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><path d="m22 6-10 7L2 6"></path></svg
            > info@saraswatishikshaniketan.edu.in</a
          ></span
        >
      </div>
      <span class="topbar-badge"
        ><svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="8" r="6"></circle><path
            d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"></path></svg
        > Admissions Open — Nursery to Class 11, 2026-27</span
      >
    </div>
  </div>
  <div class="container navbar">
    <a href="/" class="brand">
      <svg
        class="brand-mark"
        viewBox="0 0 64 64"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label="Saraswati Shiksha Niketan Inter College crest"
      >
        <path
          d="M32 3 8 12v16c0 16 10.5 26.5 24 33 13.5-6.5 24-17 24-33V12L32 3Z"
          fill="#1E3A8A"></path>
        <path d="M32 3 8 12v16c0 16 10.5 26.5 24 33V3Z" fill="#142a63"></path>
        <path d="M20 28c8-3 16-3 24 0v3c-8-3-16-3-24 0Z" fill="#F8FAFC"></path>
        <path
          d="M32 15c-1.8 2.6-3.4 3.6-3.4 6.4a3.4 3.4 0 0 0 6.8 0c0-2.8-1.6-3.8-3.4-6.4Z"
          fill="#C89B3C"></path>
        <path d="M22 34c3.5-1.4 6.7-2 10-2v9c-3.3 0-6.5.6-10 2Z" fill="#06B6D4"
        ></path>
        <path d="M42 34c-3.5-1.4-6.7-2-10-2v9c3.3 0 6.5.6 10 2Z" fill="#0891B2"
        ></path>
      </svg>
      <span class="brand-text">
        <span class="name">Saraswati Shiksha Niketan</span>
        <span class="tag">Inter College · Ghaziabad</span>
      </span>
    </a>
    <nav class="nav-menu" aria-label="Primary">
      <div class="nav-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
        <HeaderLink href="/academics">Academics</HeaderLink>
        <HeaderLink href="/admissions">Admissions</HeaderLink>
        <HeaderLink href="/faculty">Faculty</HeaderLink>
        <HeaderLink href="/campus-facilities">Facilities</HeaderLink>
        <HeaderLink href="/student-life">Student Life</HeaderLink>
        <HeaderLink href="/gallery">Gallery</HeaderLink>
        <HeaderLink href="/news-events">News</HeaderLink>
        <HeaderLink href="/contact">Contact</HeaderLink>
      </div>
      <div class="nav-cta">
        <a href="/contact" class="btn btn-dark btn-sm">Apply Now</a>
      </div>
    </nav>
    <button
      class="hamburger"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<span class="overlay"></span>
<nav class="mobile-nav" aria-label="Mobile">

  <!-- Close Button -->
  <button class="mobile-close" aria-label="Close Menu">
    ✕
  </button>

  <HeaderLink href="/">Home</HeaderLink>
  <HeaderLink href="/about">About</HeaderLink>
  <HeaderLink href="/academics">Academics</HeaderLink>
  <HeaderLink href="/admissions">Admissions</HeaderLink>
  <HeaderLink href="/faculty">Faculty</HeaderLink>
  <HeaderLink href="/campus-facilities">Facilities</HeaderLink>
  <HeaderLink href="/student-life">Student Life</HeaderLink>
  <HeaderLink href="/gallery">Gallery</HeaderLink>
  <HeaderLink href="/news-events">News</HeaderLink>
  <HeaderLink href="/contact">Contact</HeaderLink>

  <a href="/contact" class="btn btn-dark btn-block mt-lg">Apply Now</a>

</nav>
