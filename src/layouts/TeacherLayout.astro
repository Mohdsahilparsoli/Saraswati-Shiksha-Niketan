---
import "../styles/global.css";
import "../styles/t-portal.css";

import Header from "../components/student/Header.astro";
import Footer from "../components/student/Footer.astro";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
