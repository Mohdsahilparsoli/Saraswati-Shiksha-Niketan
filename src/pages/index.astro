---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={"Saraswati Shiksha Niketan Inter College | Best CBSE-Style Co-Ed School in Ghaziabad"} description={"Saraswati Shiksha Niketan Inter College, Vijay Nagar, Ghaziabad — a co-educational school for Nursery to Class 12 offering quality academics, modern facilities, and holistic development."} />
	</head>
	<body>
		<Header />
		<main>
			  <section class="hero">
    <div class="hero-media"><img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1600&q=80" alt="Students and teachers walking across the Saraswati Shiksha Niketan campus" loading="lazy" class=""></div>
    <div class="container">
      <div class="hero-content">
        <span class="eyebrow">Ghaziabad's Trusted Co-Ed Institution Since 1999</span>
        <h1>Inspiring Excellence, Building Future Leaders</h1>
        <p class="lede">Quality education, strong values, and holistic development for every student — from their first day in Nursery to the threshold of a bright future in Class 12.</p>
        <div class="hero-actions">
          <a href="/admissions" class="btn btn-primary">Apply for Admission <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
          <a href="/contact" class="btn btn-outline">Schedule a School Visit</a>
        </div>
        <div class="hero-stats">
          <div><div class="stat-num">26+</div><div class="stat-label">Years of Excellence</div></div>
          <div><div class="stat-num">2,400+</div><div class="stat-label">Students</div></div>
          <div><div class="stat-num">98%</div><div class="stat-label">Board Result</div></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="reveal">
        <span class="eyebrow">Welcome to SSNIC</span>
        <h2>A School Built on Knowledge, Character, and Care</h2>
        <p class="lede">Saraswati Shiksha Niketan Inter College has been a cornerstone of quality education in Vijay Nagar, Ghaziabad, since 1999. We provide a nurturing, disciplined, and academically rigorous environment for students from Nursery through Intermediate (Class 12), affiliated to the Uttar Pradesh Board.</p>
        <p>Our philosophy is simple: every child learns differently, and every child deserves teachers who notice. We combine a strong academic core with sports, arts, and values education so that students leave us not just qualified, but ready.</p>
        <ul class="check-list mt-lg">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Experienced, UP Board-trained faculty across all levels</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Smart classrooms, science and computer laboratories</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Safe transport network across Ghaziabad and Vijay Nagar</li>
        </ul>
      </div>
      <div class="reveal image-frame"><img src="https://images.unsplash.com/photo-1519452575417-564c1401ecc0?auto=format&fit=crop&w=1200&q=80" alt="Students raising hands during class at Saraswati Shiksha Niketan" loading="lazy" class=""></div>
    </div>
  </section>

  <section class="section alt">
    <div class="container split reverse-mobile">
      <div class="reveal image-frame"><img src="https://images.unsplash.com/photo-1580894732444-8ecded7900cd?auto=format&fit=crop&w=800&q=80" alt="Principal of Saraswati Shiksha Niketan Inter College" loading="lazy" class=""></div>
      <div class="reveal">
        <span class="eyebrow">Principal's Message</span>
        <h2>&ldquo;We prepare children for the world, not just the exam.&rdquo;</h2>
        <p class="lede">Education today must do more than fill notebooks — it must build confident, curious, and compassionate human beings. At Saraswati Shiksha Niketan, our teachers know every child by name, and our classrooms are designed to make learning feel like discovery, not duty.</p>
        <p>I invite every parent to visit our campus, meet our faculty, and see for yourself the environment we have built for your child's growth.</p>
        <p style="margin-top:1.2rem;font-family:var(--font-display);font-weight:600;color:var(--color-primary-dark);">Mrs. Sunita Sharma<br><span style="font-weight:400;color:var(--color-text-soft);font-size:0.88rem;">Principal, Saraswati Shiksha Niketan Inter College</span></p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Why Families Choose Us</span>
        <h2>What Sets Our School Apart</h2>
        <p class="lede" style="margin-inline:auto;">A well-rounded education, built on four pillars that guide everything we do in the classroom and beyond.</p>
      </div>
      <div class="grid grid-4">
        <div class="card reveal">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
          <h3>Academic Rigour</h3>
          <p>A structured, UP Board-aligned curriculum delivered through experienced teachers and regular assessment.</p>
        </div>
        <div class="card reveal">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg></div>
          <h3>Values &amp; Discipline</h3>
          <p>Character education woven into daily school life, building respect, responsibility, and integrity.</p>
        </div>
        <div class="card reveal">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg></div>
          <h3>Modern Facilities</h3>
          <p>Smart classrooms, science labs, a well-stocked library, and dedicated sports infrastructure.</p>
        </div>
        <div class="card reveal">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg></div>
          <h3>Safety First</h3>
          <p>CCTV-monitored campus, trained transport staff, and an on-campus medical room for peace of mind.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Academic Excellence</span>
        <h2>Results Our Students and Parents Are Proud Of</h2>
      </div>
      <div class="grid grid-3">
        <div class="card card-ribbon reveal" data-ribbon="Topper">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 4h10v5a5 5 0 0 1-10 0Z"/><path d="M17 5.5h2.5a2 2 0 0 1 0 4H17"/><path d="M7 5.5H4.5a2 2 0 0 0 0 4H7"/></svg></div>
          <h3>Class 12 — 2025-26 Board Results</h3>
          <p>98% of our Intermediate students cleared the UP Board examination, with 34 students scoring above 90%.</p>
        </div>
        <div class="card card-ribbon reveal" data-ribbon="Topper">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 4h10v5a5 5 0 0 1-10 0Z"/><path d="M17 5.5h2.5a2 2 0 0 1 0 4H17"/><path d="M7 5.5H4.5a2 2 0 0 0 0 4H7"/></svg></div>
          <h3>Class 10 — 2025-26 Board Results</h3>
          <p>96% pass rate at High School level, with our top scorer, Aditi Verma, achieving 96.4% aggregate.</p>
        </div>
        <div class="card reveal">
          <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"/></svg></div>
          <h3>Beyond the Classroom</h3>
          <p>State-level science olympiad winners, district sports champions, and NCC cadets recognised this year.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="stats-strip">
    <div class="container stats-grid">
      <div class="stat-item"><div class="stat-num"><span data-counter="26" data-suffix="+">0</span></div><div class="stat-label">Years of Legacy</div></div>
      <div class="stat-item"><div class="stat-num"><span data-counter="2400" data-suffix="+">0</span></div><div class="stat-label">Students Enrolled</div></div>
      <div class="stat-item"><div class="stat-num"><span data-counter="85" data-suffix="+">0</span></div><div class="stat-label">Qualified Faculty</div></div>
      <div class="stat-item"><div class="stat-num"><span data-counter="98" data-suffix="%">0</span></div><div class="stat-label">Board Pass Rate</div></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Campus Life</span>
        <h2>Featured Facilities</h2>
        <p class="lede" style="margin-inline:auto;">A campus designed to support learning, play, and everything in between.</p>
      </div>
      <div class="grid grid-3">
        <div class="card reveal">
          <div class="image-frame mb-0" style="margin-bottom:1rem;"><img src="https://images.unsplash.com/photo-1554774853-b415df9eeb92?auto=format&fit=crop&w=1200&q=80" alt="Students working in the school science laboratory" loading="lazy" class=""></div>
          <h3>Science Laboratories</h3>
          <p>Fully equipped physics, chemistry, and biology labs for hands-on, curiosity-driven learning.</p>
        </div>
        <div class="card reveal">
          <div class="image-frame" style="margin-bottom:1rem;"><img src="https://images.unsplash.com/photo-1544717297-fa95b6ee9643?auto=format&fit=crop&w=1200&q=80" alt="Students using computers in the school computer laboratory" loading="lazy" class=""></div>
          <h3>Computer Laboratory</h3>
          <p>Modern systems and structured IT curriculum from Class 3 onward, including coding basics.</p>
        </div>
        <div class="card reveal">
          <div class="image-frame" style="margin-bottom:1rem;"><img src="https://images.unsplash.com/photo-1461896836934-ffe607ba8211?auto=format&fit=crop&w=1200&q=80" alt="Students playing on the school sports ground" loading="lazy" class=""></div>
          <h3>Sports Ground</h3>
          <p>A full-size playground for athletics, cricket, football, kabaddi, and annual sports meets.</p>
        </div>
      </div>
      <div class="text-center mt-lg">
        <a href="/campus-facilities" class="btn btn-dark">Explore All Facilities <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Stay Updated</span>
        <h2>Latest News &amp; Announcements</h2>
      </div>
      <div class="grid grid-3">
        <div class="event-card reveal">
          <div class="event-date"><div class="d">18</div><div class="m">Jul</div></div>
          <div><h4>Admission Window for Nursery–Class 8 Extended</h4><p>Limited seats remaining for the 2026-27 academic session across primary and middle school.</p></div>
        </div>
        <div class="event-card reveal">
          <div class="event-date"><div class="d">02</div><div class="m">Aug</div></div>
          <div><h4>Annual Inter-House Science Exhibition</h4><p>Students from Classes 6-12 will showcase working models across all four school houses.</p></div>
        </div>
        <div class="event-card reveal">
          <div class="event-date"><div class="d">15</div><div class="m">Aug</div></div>
          <div><h4>Independence Day Celebration &amp; Flag Hoisting</h4><p>Special assembly, patriotic performances, and a felicitation for last year's board toppers.</p></div>
        </div>
      </div>
      <div class="text-center mt-lg">
        <a href="/news-events" class="btn btn-outline" style="color:var(--color-primary);border-color:var(--color-primary);">View All News &amp; Events</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Parent Voices</span>
        <h2>What Our School Community Says</h2>
      </div>
      <div class="testimonial-slider">
        <div class="testimonial-slide is-active">
          <p class="testimonial-quote">&ldquo;My daughter has grown so much in confidence since joining SSNIC. The teachers genuinely care, and the school communicates with parents regularly.&rdquo;</p>
          <p class="testimonial-author">Rekha Agarwal</p>
          <p class="testimonial-role">Parent, Class 6</p>
        </div>
        <div class="testimonial-slide">
          <p class="testimonial-quote">&ldquo;The balance between academics and extracurriculars is exactly what we wanted for our son. He looks forward to school every single day.&rdquo;</p>
          <p class="testimonial-author">Vikram Chaudhary</p>
          <p class="testimonial-role">Parent, Class 9</p>
        </div>
        <div class="testimonial-slide">
          <p class="testimonial-quote">&ldquo;From Nursery to now Class 12, this school has felt like an extended family. The board results speak for themselves.&rdquo;</p>
          <p class="testimonial-author">Priya &amp; Sanjay Malhotra</p>
          <p class="testimonial-role">Parents, Class 12</p>
        </div>
        <div class="slider-dots"></div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="admission-banner reveal">
        <div>
          <span class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"/></svg> Admissions Open — 2026-27</span>
          <h2 class="mt-lg" style="margin-top:0.8rem;">Give Your Child a Strong Foundation</h2>
          <p>Seats are limited for Nursery through Class 11. Apply online in under five minutes or schedule a campus visit.</p>
        </div>
        <div class="hero-actions" style="margin-top:0;">
          <a href="/admissions" class="btn btn-gold">Start Application</a>
          <a href="tel:+911204567890" class="btn btn-outline">Call Admissions Desk</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="inquire">
    <div class="container split">
      <div class="reveal">
        <span class="eyebrow">Quick Inquiry</span>
        <h2>Have Questions? We're Happy to Help</h2>
        <p class="lede">Share a few details and our admissions team will get back to you within one working day with fee structure, seat availability, and a campus tour slot.</p>
        <ul class="check-list mt-lg">
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Response within 24 hours</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> No obligation, no pressure</li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Free campus tour on request</li>
        </ul>
      </div>
      <div class="form-card reveal">
        <div class="form-success" role="status"></div>
        <form data-validate>
          <div class="form-row">
            <div class="field"><label for="h-name">Parent's Name</label><input type="text" id="h-name" required><span class="error-msg">Please enter your name.</span></div>
            <div class="field"><label for="h-phone">Phone Number</label><input type="tel" id="h-phone" data-phone required><span class="error-msg">Please enter a valid 10-digit number.</span></div>
          </div>
          <div class="field"><label for="h-email">Email Address</label><input type="email" id="h-email" required><span class="error-msg">Please enter a valid email.</span></div>
          <div class="field"><label for="h-class">Class Interested In</label>
            <select id="h-class" required>
              <option value="">Select a class</option>
              <option>Nursery / LKG / UKG</option>
              <option>Class 1 - 5</option>
              <option>Class 6 - 8</option>
              <option>Class 9 - 10</option>
              <option>Class 11 - 12</option>
            </select>
            <span class="error-msg">Please select a class.</span>
          </div>
          <button class="btn btn-primary btn-block" type="submit">Submit Inquiry <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg></button>
        </form>
      </div>
    </div>
  </section>
		</main>
		<Footer />
	</body>
</html>
