---
import StudentLayout from "../../layouts/StudentLayout.astro";
---

<StudentLayout title="Student Login | Saraswati Shiksha Niketan Inter College">

<main class="portal-main">
  <div class="container">

    <div class="portal-narrow">

      <div class="portal-card">

        <h1>Student Login</h1>

        <p class="sub">
          Log in to view your profile, pay fees, or request class promotion.
        </p>

        <form  action="/student/dashboard" novalidate>

          <div class="portal-field">
            <label for="email">Email Address</label>

            <input
              type="email"
              id="email"
              name="email"
              required
              autofocus
            />
          </div>

          <div class="portal-field">
            <label for="password">Password</label>

            <input
              type="password"
              id="password"
              name="password"
              required
            />
          </div>

          <button
            class="btn btn-primary btn-block"
            type="submit"
          >
            Log In
          </button>

        </form>

        <div class="portal-link-row">
          New student?

          <a href="/student/register">
            Register here
          </a>
        </div>

      </div>

    </div>

  </div>
</main>

</StudentLayout>