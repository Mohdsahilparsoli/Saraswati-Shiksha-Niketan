---
import StudentLayout from "../../layouts/StudentLayout.astro";
---

<StudentLayout title="Dashboard | Saraswati Shiksha Niketan Inter College">

<main class="portal-main">
  <div class="container">

    <div class="portal-card">
      <h1>Welcome back, Ananya Sharma</h1>
      <p class="sub">
        Admission No. SSN-2024-0142 &middot;
        Class 11 - Science &middot;
        2025-26
      </p>
    </div>

    <div class="portal-grid">

      <div class="portal-card portal-stat">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
        </div>

        <div>
          <div class="value">Class 11 - Science</div>
          <div class="label">Current Class</div>
        </div>
      </div>

      <div class="portal-card portal-stat">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>

        <div>
          <div class="value">₹15,000</div>
          <div class="label">Fee Balance Due</div>
        </div>
      </div>

      <div class="portal-card portal-stat">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>

        <div>
          <div class="value">
            <span class="badge pending">Pending</span>
          </div>

          <div class="label">Promotion Status</div>
        </div>
      </div>

    </div>

    <div class="portal-card">

      <h2>Quick Actions</h2>

      <div class="portal-actions">

        <a class="btn btn-primary btn-sm" href="/student/fee-payment">
          Pay Fees
        </a>

        <a class="btn btn-outline btn-sm" href="/student/profile">
          Edit Profile
        </a>

        <a class="btn btn-outline btn-sm" href="/student/promote-class">
          Request Class Promotion
        </a>

      </div>

    </div>

  </div>
</main>

</StudentLayout>